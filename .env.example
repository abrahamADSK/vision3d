# Vision3D — Environment variables
#
# Copy to .env and adjust values for your setup.

# API authentication (leave empty for open access on LAN)
GPU_API_KEY=

# Paths (defaults shown — adjust to your installation)
GPU_MODELS_DIR=~/ai-studio/vision/hf_models
GPU_WORK_DIR=~/ai-studio/reference/3d_output
GPU_VISION_DIR=~/ai-studio/vision
