# Vision3D — Environment variables
#
# Copy to .env and adjust values for your setup.
# All paths default to relative locations inside the vision3d directory.

# API authentication (leave empty for open access on LAN)
GPU_API_KEY=

# Paths — override only if your layout differs from defaults
# GPU_MODELS_DIR=./hf_models          # Hunyuan3D-2 model weights
# GPU_WORK_DIR=./output               # Job output directory
# GPU_VISION_DIR=.                     # Vision3D install directory
